---
import { Image } from "astro:assets";
import logoimg from "../images/logo.svg";
import { ChevronDown, Monitor, Sun, Moon } from "@lucide/astro";
import FlickeringGrid from "./FlickeringGrid.jsx";
const { page } = Astro.props;

// Helper function to determine if a link is active
const isActive = (path: string) => {
  return page === path;
};
---

<!-- Desktop Navigation -->
<div class="flex items-center justify-center z-[99] sticky top-0">
  <!-- Flickering Grid Canvas Effect Behind Navbar -->
  <div class="absolute inset-0 top-0 left-0 right-0 h-[120px] overflow-hidden z-0 w-full" style="mask-image:linear-gradient(to bottom, black, transparent);-webkit-mask-image:linear-gradient(to bottom, black, transparent)">
    <FlickeringGrid client:load />
  </div>

  <nav
    id="desktop-nav"
    class="w-full max-w-4xl mx-auto px-6 sm:px-15 py-4 z-[99] sm:flex hidden items-center justify-start"
    role="navigation"
    aria-label="Main navigation"
  >
    <ul class="flex gap-1 bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full p-1">
      <li>
        <a
          href="/"
          class={`${isActive("home") ? "bg-white dark:bg-neutral-800 text-gray-900 dark:text-gray-100" : "bg-transparent text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"} flex items-center px-4 py-1.5 rounded-full font-product-sans text-sm font-bold transition-all duration-300`}
          aria-label="Home"
        >
          home
        </a>
      </li>
      <li>
        <a
          href="/projects"
          class={`${isActive("projects") ? "bg-white dark:bg-neutral-800 text-gray-900 dark:text-gray-100" : "bg-transparent text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"} flex items-center px-4 py-1.5 rounded-full font-product-sans text-sm font-bold transition-all duration-300`}
          aria-label="View my projects"
        >
          projects
        </a>
      </li>
      <li>
        <a
          href="/blog"
          class={`${isActive("blog") ? "bg-white dark:bg-neutral-800 text-gray-900 dark:text-gray-100" : "bg-transparent text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"} flex items-center px-4 py-1.5 rounded-full font-product-sans text-sm font-bold transition-all duration-300`}
          aria-label="Read my blog posts"
        >
          blog
        </a>
      </li>
      <li>
        <a
          href="#about"
          class={`${isActive("about") ? "bg-white dark:bg-neutral-800 text-gray-900 dark:text-gray-100" : "bg-transparent text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"} flex items-center px-4 py-1.5 rounded-full font-product-sans text-sm font-bold transition-all duration-300`}
          aria-label="About me"
        >
          about
        </a>
      </li>
    </ul>

    <!-- Theme Switcher -->
    <div class="ml-auto flex items-center gap-0.5 bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full p-1" role="radiogroup" aria-label="Theme switcher">
      <button
        data-theme-btn="system"
        class="theme-btn p-1.5 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-all duration-300"
        aria-label="System theme"
        title="System"
      >
        <Monitor class="w-4 h-4" />
      </button>
      <button
        data-theme-btn="light"
        class="theme-btn p-1.5 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-all duration-300"
        aria-label="Light theme"
        title="Light"
      >
        <Sun class="w-4 h-4" />
      </button>
      <button
        data-theme-btn="dark"
        class="theme-btn p-1.5 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-all duration-300"
        aria-label="Dark theme"
        title="Dark"
      >
        <Moon class="w-4 h-4" />
      </button>
    </div>
  </nav>

  <!-- Mobile Navigation -->
  <nav
    class="bg-gray-100 dark:bg-neutral-900 text-gray-900 dark:text-gray-100 px-4 py-3 mt-3 border border-gray-200 dark:border-neutral-800 w-fit gap-2 fixed items-center z-[99] top-0 sm:hidden flex"
    data-aos="fade-down"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <a href="/" class="logo" aria-label="Home">
      <Image
        src={logoimg}
        alt="Ajmal Razaq logo"
        loading="eager"
        class="logo-image w-8"
      />
    </a>

    <div class="w-px h-6 bg-gray-300"></div>

    <button class="flex items-center gap-1.5 text-gray-600 dark:text-gray-300 font-product-sans text-sm px-2 py-1 hover:bg-gray-200 dark:hover:bg-neutral-800 transition-all duration-300">
      <span>menu</span>
      <ChevronDown class="w-4 h-4" aria-hidden="true" />
    </button>

    <div class="w-px h-6 bg-gray-300 dark:bg-neutral-700"></div>

    <!-- Mobile Theme Switcher -->
    <div class="flex items-center gap-0.5" role="radiogroup" aria-label="Theme switcher">
      <button
        data-theme-btn="system"
        class="theme-btn p-1.5 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-all duration-300"
        aria-label="System theme"
      >
        <Monitor class="w-3.5 h-3.5" />
      </button>
      <button
        data-theme-btn="light"
        class="theme-btn p-1.5 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-all duration-300"
        aria-label="Light theme"
      >
        <Sun class="w-3.5 h-3.5" />
      </button>
      <button
        data-theme-btn="dark"
        class="theme-btn p-1.5 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-all duration-300"
        aria-label="Dark theme"
      >
        <Moon class="w-3.5 h-3.5" />
      </button>
    </div>
  </nav>
</div>

<style>
  .theme-btn.active {
    background-color: white;
    color: #374151;
  }
  :global(.dark) .theme-btn.active {
    background-color: #262626;
    color: #e5e7eb;
  }
</style>

<script>
  function applyTheme(theme: string) {
    const root = document.documentElement;
    if (theme === 'dark') {
      root.classList.add('dark');
    } else if (theme === 'light') {
      root.classList.remove('dark');
    } else {
      // system
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        root.classList.add('dark');
      } else {
        root.classList.remove('dark');
      }
    }
  }

  function setActiveButton(theme: string) {
    document.querySelectorAll('.theme-btn').forEach(btn => {
      btn.classList.remove('active');
      if (btn.getAttribute('data-theme-btn') === theme) {
        btn.classList.add('active');
      }
    });
  }

  // Initialize
  const savedTheme = localStorage.getItem('theme') || 'system';
  applyTheme(savedTheme);
  setActiveButton(savedTheme);

  // Listen for clicks
  document.querySelectorAll('[data-theme-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const theme = btn.getAttribute('data-theme-btn') || 'system';
      localStorage.setItem('theme', theme);
      applyTheme(theme);
      setActiveButton(theme);
    });
  });

  // Listen for system preference changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (localStorage.getItem('theme') === 'system' || !localStorage.getItem('theme')) {
      applyTheme('system');
    }
  });
</script>

