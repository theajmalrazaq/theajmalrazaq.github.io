<footer
  class="py-8 px-4 sm:px-6 relative z-20 border-t border-gray-100 dark:border-neutral-900 overflow-hidden"
  role="contentinfo"
>
  <div class="max-w-4xl mx-auto relative z-10">
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-6 text-center sm:text-left"
    >
      <!-- Left: Copyright -->
      <div class="flex flex-col gap-1">
        <p
          class="text-gray-400 dark:text-gray-500 text-xs font-product-sans font-medium"
        >
          © 2025 ajmal razaq • design engineer ✨
        </p>
        <p
          class="text-gray-400 dark:text-gray-500 text-[10px] font-product-sans uppercase tracking-wider"
        >
          built with design & code
        </p>
      </div>

      <!-- Right: Social Links -->
      <div class="flex gap-4 items-center justify-center">
        <a
          href="https://github.com/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 dark:text-gray-500 hover:text-accent transition-colors duration-300"
          aria-label="GitHub"
        >
          <i class="hgi-stroke hgi-github-01 text-lg"></i>
        </a>
        <a
          href="https://linkedin.com/in/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 dark:text-gray-500 hover:text-accent transition-colors duration-300"
          aria-label="LinkedIn"
        >
          <i class="hgi hgi-stroke hgi-linkedin-01 text-lg"></i>
        </a>
        <a
          href="https://behance.net/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 dark:text-gray-500 hover:text-accent transition-colors duration-300"
          aria-label="Behance"
        >
          <i class="hgi hgi-stroke hgi-behance-02 text-lg"></i>
        </a>
      </div>
    </div>
  </div>
</footer>
