<footer
  class="w-full py-12 px-6 sm:px-15 border-t border-gray-100 dark:border-neutral-900 mt-20"
>
  <div
    class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-8"
  >
    <div class="flex flex-col items-center sm:items-start gap-2">
      <h3
        class="text-lg font-product-sans font-bold text-gray-900 dark:text-gray-100"
      >
        ajmal razaq
      </h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans">
        Design Engineer & Developer
      </p>
    </div>

    <div class="flex items-center gap-6">
      <a
        href="https://github.com/theajmalrazaq"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-accent transition-colors duration-300"
        aria-label="GitHub"
      >
        <i class="hgi-stroke hgi-github-01 text-xl"></i>
      </a>
      <a
        href="https://linkedin.com/in/theajmalrazaq"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-accent transition-colors duration-300"
        aria-label="LinkedIn"
      >
        <i class="hgi hgi-stroke hgi-linkedin-01 text-xl"></i>
      </a>
      <a
        href="https://behance.net/theajmalrazaq"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-accent transition-colors duration-300"
        aria-label="Behance"
      >
        <i class="hgi hgi-stroke hgi-behance-02 text-xl"></i>
      </a>
    </div>
  </div>

  <div
    class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4 mt-12 pt-8 border-t border-gray-50 dark:border-neutral-950"
  >
    <p class="text-xs text-gray-400 dark:text-gray-600 font-product-sans">
      © {new Date().getFullYear()} Ajmal Razaq. All rights reserved.
    </p>
    <p class="text-xs text-gray-400 dark:text-gray-600 font-product-sans">
      Built with <span class="text-accent/60">Astro</span> & ❤️
    </p>
  </div>
</footer>
