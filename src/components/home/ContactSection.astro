---
import { Mail, Copy } from "@lucide/astro";
---

<link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />

<section
  class="relative w-full flex justify-center overflow-hidden z-10 bg-white dark:bg-black"
  id="contact"
  role="region"
  data-aos="focus-up"
  aria-labelledby="contact-heading"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    
    <!-- Heading -->
    <div data-aos="focus-up">
      <h2
        id="contact-heading"
        class="text-[50px] [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100"
      >
        contact
      </h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mt-2">let's connect</p>
    </div>

    <!-- Description -->
    <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl" data-aos="focus-up" data-aos-delay="100">
      I'm always open to new opportunities, collaborations, and interesting conversations. Whether you have a project in mind or just want to say hello, feel free to reach out.
    </p>

    <!-- Work Types -->
    <div class="flex flex-wrap gap-3" data-aos="focus-up" data-aos-delay="150">
      {["Full-time", "Part-time", "Contract", "Freelance"].map((type) => (
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-50 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full text-gray-700 dark:text-gray-300 hover:bg-accent/10 hover:border-accent/30 transition-all duration-300">
          <div class="w-2 h-2 bg-accent rounded-full"></div>
          <span class="text-sm font-product-sans">{type}</span>
        </span>
      ))}
    </div>

    <!-- Contact Card -->
    <div class="mt-4" data-aos="focus-up" data-aos-delay="200">
      <div class="flex gap-4 sm:gap-6 items-start group">
        <!-- Icon -->
        <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center text-xl border border-accent/20">
          <Mail size="20" class="text-accent" />
        </div>
        
        <!-- Content -->
        <div class="flex-1">
          <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 font-product-sans mb-1">Email</p>
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-2xl font-product-sans font-bold text-gray-900 dark:text-gray-100" id="email-text">theajmalrazaq@gmail.com</h3>
          </div>
          <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed mb-4">Click the button below to copy my email address.</p>
          
          <button
            id="email-copy-btn"
            class="inline-flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-full font-product-sans text-sm hover:bg-accent dark:hover:bg-accent dark:hover:text-white transition-all duration-300"
            aria-label="Copy email address"
          >
            <Copy size="14" />
            <span>Copy Email</span>
          </button>
          
          <!-- Copy Success Message -->
          <span
            id="copy-success"
            class="ml-3 text-accent font-product-sans text-sm opacity-0 transition-opacity duration-300"
          >
            ✓ Copied!
          </span>
        </div>
      </div>
    </div>

    <!-- Social Links -->
    <div class="mt-4" data-aos="focus-up" data-aos-delay="250">
      <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mb-4">Or connect with me on social media:</p>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="https://github.com/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="GitHub profile"
        >
          <i class="hgi-stroke hgi-github-01 text-lg"></i>
          <span>GitHub</span>
        </a>
        <a
          href="https://linkedin.com/in/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="LinkedIn profile"
        >
          <i class="hgi hgi-stroke hgi-linkedin-01 text-lg"></i>
          <span>LinkedIn</span>
        </a>
        <a
          href="https://x.com/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="X (Twitter) profile"
        >
          <i class="hgi hgi-stroke hgi-new-twitter text-lg"></i>
          <span>X (Twitter)</span>
        </a>
        <a
          href="https://behance.net/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="Behance portfolio"
        >
          <i class="hgi hgi-stroke hgi-behance-02 text-lg"></i>
          <span>Behance</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const emailBtn = document.getElementById('email-copy-btn');
  const emailText = document.getElementById('email-text');
  const copySuccess = document.getElementById('copy-success');
  
  emailBtn?.addEventListener('click', async () => {
    const email = emailText?.textContent?.trim();
    if (email) {
      await navigator.clipboard.writeText(email);
      if (copySuccess) {
        copySuccess.style.opacity = '1';
        setTimeout(() => {
          copySuccess.style.opacity = '0';
        }, 2000);
      }
    }
  });
</script>
