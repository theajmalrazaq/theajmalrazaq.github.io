---
import { getCollection } from "astro:content";
import BlogList from "./BlogList.jsx";

// Get all blog posts from content collection
const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((post) => ({
    slug: post.id,
    title: post.data.title,
    date: post.data.date.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }),
  }));
---

<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="blog-heading"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    <BlogList posts={posts} client:load />
  </div>
</section>
