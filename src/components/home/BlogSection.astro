---
---

<link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />

<section
  class="relative w-full flex justify-center overflow-hidden z-10 bg-white dark:bg-black"
  aria-labelledby="blog-heading"
  data-aos="focus-up"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    
    <!-- Heading with Post Count and View All Button -->
    <div class="flex items-end justify-between gap-4" data-aos="focus-up">
      <div>
        <h2 class="text-[50px] [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100" id="blog-heading">
          blog
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mt-2">5 posts</p>
      </div>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full text-gray-700 dark:text-gray-300 hover:bg-accent/10 hover:border-accent/30 transition-all duration-300 font-product-sans text-xs"
        aria-label="View all blog posts"
      >
        <span>View All</span>
        <i class="hgi hgi-stroke hgi-arrow-right-01"></i>
      </a>
    </div>

    <!-- Description -->
    <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl" data-aos="focus-up" data-aos-delay="100">
      My thoughts on <strong>software development</strong>, <strong>life</strong>, and more.
    </p>

    <!-- Blog Posts List -->
    <div class="flex flex-col gap-6 mt-4" data-aos="focus-up" data-aos-delay="200">
      {[
        {
          id: 1,
          title: "Testing React Applications: A Practical Guide",
          date: "2024-12-14",
        },
        {
          id: 2,
          title: "REST API Design Principles That Stand the Test of Time",
          date: "2024-12-12",
        },
        {
          id: 3,
          title: "Git Workflow Guide: From Chaos to Clarity",
          date: "2024-12-10",
        },
        {
          id: 4,
          title: "TypeScript Best Practices for Clean, Maintainable Code",
          date: "2024-12-08",
        },
        {
          id: 5,
          title: "10 Next.js Performance Tips for Production Apps",
          date: "2024-12-05",
        },
      ].map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="flex gap-4 sm:gap-6 items-start group hover:opacity-75 transition-opacity duration-300"
          data-aos="focus-up"
        >
          <!-- Post Number -->
          <div class="flex-shrink-0 text-gray-500 dark:text-gray-400 [font-family:'GeistPixelSquare'] text-lg font-bold w-12">
            {String(post.id).padStart(2, "0")}.
          </div>
          
          <!-- Post Content -->
          <div class="flex-1 flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <h3 class="text-lg font-product-sans text-gray-900 dark:text-gray-100 lowercase">{post.title}</h3>
              <i class="hgi hgi-stroke hgi-arrow-right-01 text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0 text-base"></i>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans">
              {post.date}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
