---
---

<link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />

<section
  class="relative w-full flex justify-center overflow-hidden z-10 bg-white dark:bg-black"
  aria-labelledby="skills-heading"
  data-aos="focus-up"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    
    <!-- Heading -->
    <h2
      id="skills-heading"
      class="text-[50px] [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100"
      data-aos="focus-up"
    >
      skills
    </h2>

    <!-- Skills Grid -->
    <div class="flex flex-wrap gap-3" data-aos="focus-up" data-aos-delay="100">
      {[
        { name: "React", icon: "hgi-react" },
        { name: "Next.js", icon: "hgi-nextjs" },
        { name: "TypeScript", icon: "hgi-typescript-01" },
        { name: "Node.js", icon: "hgi-nodejs" },
        { name: "Python", icon: "hgi-python" },
        { name: "Go", icon: "hgi-go" },
        { name: "Postgres", icon: "hgi-postgresql" },
        { name: "Docker", icon: "hgi-docker" },
        { name: "Kubernetes", icon: "hgi-kubernetes" },
        { name: "Java", icon: "hgi-java" },
        { name: "C++", icon: "hgi-cplusplus" },
      ].map((skill) => (
        <div
          class="inline-flex items-center gap-2 px-4 py-2 bg-gray-50 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full text-gray-700 dark:text-gray-300 hover:bg-accent/10 hover:border-accent/30 transition-all duration-300"
          data-aos="focus-up"
        >
          <i class={`hgi hgi-stroke ${skill.icon} text-gray-600 dark:text-gray-400`}></i>
          <span class="text-sm font-product-sans text-gray-600 dark:text-gray-400">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
