---

---

<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="skills-heading"
  data-aos="focus-up"
>
  <div
    class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10"
  >
    <!-- Heading -->
    <h2
      id="skills-heading"
      class="text-[50px] [font-family:'GeistPixelGrid'] text-gray-900 dark:text-gray-100 text-center"
      data-aos="focus-up"
    >
      skills & tools
    </h2>

    <!-- Skills Grid -->
    <div
      class="flex flex-wrap items-center justify-center gap-3"
      data-aos="focus-up"
      data-aos-delay="100"
    >
      {
        [
          "HTML",
          "CSS",
          "JavaScript",
          "SCSS",
          "React JS",
          "Tailwind",
          "Bulma CSS",
          "Bootstrap",
          "shadcn",
          "Astro JS",
          "Node JS",
          "Python",
          "C++",
          "C",
          "Assembly",
          "SQL",
          "MySQL",
          "PostgreSQL",
          "Supabase",
          "GitHub",
          "Shell",
          "Linux",
          "Figma",
          "Jupyter Notebook",
        ].map((skill) => (
          <div
            class="inline-flex items-center px-4 py-2 bg-gray-50 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full hover:bg-accent/10 hover:border-accent/30 transition-all duration-300"
            data-aos="focus-up"
          >
            <span class="text-sm font-product-sans text-gray-600 dark:text-gray-400">
              {skill}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
