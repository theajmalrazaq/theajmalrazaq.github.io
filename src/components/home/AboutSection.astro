---
import { Image } from "astro:assets";
import devimg from "../../images/ajmalo.png";
import DotGrid from "../DotGrid.astro";
import Gallery from "../Gallery.astro";

const images = [
  { src: "/gallery/photo1.jpg", alt: "Photo 1" },
  { src: "/gallery/photo2.jpg", alt: "Photo 2" },
  { src: "/gallery/photo3.jpg", alt: "Photo 3" },
  { src: "/gallery/photo4.jpg", alt: "Photo 4" },
  { src: "/gallery/photo5.jpg", alt: "Photo 5" },
];
---

<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="about-heading"
  data-aos="focus-up"
>
  <div
    class="relative w-full max-w-4xl mx-auto px-4 sm:px-15 py-6 sm:py-8 flex flex-col gap-6 z-10 items-center"
  >
    <!-- Profile Image with DotGrid Background -->
    <div
      class="relative w-full max-w-[200px] sm:max-w-[260px] aspect-square flex items-center justify-center -mb-8 sm:-mb-12 -mt-4 sm:-mt-8"
      data-aos="focus-up"
      data-aos-delay="50"
    >
      <!-- Animated SVG Dot Grid -->
      <div class="absolute inset-0 opacity-40 dark:opacity-80 scale-[0.85] z-0">
        <DotGrid />
      </div>

      <!-- Profile Image -->
      <div class="relative z-20">
        <div
          class="group relative w-[100px] h-[100px] sm:w-[125px] sm:h-[125px] rounded-full overflow-hidden border-4 border-gray-200 dark:border-neutral-800 hover:border-accent/50 transition-all duration-300 bg-gradient-to-br from-accent/5 to-transparent shadow-xl"
          role="img"
          aria-label="Ajmal Razaq profile picture"
        >
          <Image
            src={devimg}
            alt="Ajmal Razaq portrait"
            loading="eager"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"
          >
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-2 items-center">
      <!-- About Heading -->
      <h1
        id="about-heading"
        class="text-[40px] sm:text-[50px] [font-family:'GeistPixelGrid'] text-gray-900 dark:text-gray-100 text-center"
        data-aos="focus-up"
        data-aos-delay="100"
      >
        about
      </h1>
    </div>

    <!-- About Content -->
    <div
      class="flex flex-col gap-8 max-w-4xl text-center"
      data-aos="focus-up"
      data-aos-delay="200"
    >
      <p
        class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed"
      >
        My design and coding journey started back in 8th grade, when I
        accidentally fell in love with graphic design and web development and
        never recovered. Fast forward to 2023: I got into <strong
          >FAST NU</strong
        > for <strong>Computer Science</strong>, started freelancing, and began
        networking like a pro on LinkedIn and through societies. That's when I
        teamed up with a senior who launched a design agency called <strong
          >Pixen</strong
        >. Now I work part-time as a <strong>UI/UX Designer</strong> and <strong
          >Frontend Developer</strong
        >, helping build <strong>20+ SaaS landing pages</strong>, <strong
          >web apps</strong
        >, and <strong>3+ mobile apps</strong>.
      </p>

      <p
        class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed"
      >
        I've also been an active <strong>Hacktoberfest</strong> contributor since
        2023 (yes, I keep coming back for more). I love building things that actually
        work and look good doing it. Curious? Check out my projects to see what I've
        been up to!
      </p>
    </div>

    <!-- Gallery Section -->
    <Gallery images={images} />
  </div>
</section>
