---
---


<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="experience-heading"
  data-aos="focus-up"
>
  <div class="relative w-full max-w-4xl mx-auto px-4 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    
    <!-- Heading with Experience Count -->
    <div class="flex flex-col items-center justify-center gap-2 text-center" data-aos="focus-up">
      <div>
        <h2 class="text-[40px] sm:text-[50px] [font-family:'GeistPixelGrid'] text-gray-900 dark:text-gray-100" id="experience-heading">
        experience
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mt-2">6 positions</p>
      </div>
    </div>

    <!-- Description -->
    <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl mx-auto text-center" data-aos="focus-up" data-aos-delay="100">
      My professional journey in <strong>design engineering</strong> and <strong>UI/UX</strong>.
    </p>

    <!-- Experience Items -->
    <div class="flex flex-col gap-10 mt-4" data-aos="focus-up" data-aos-delay="200">
      {[
        {
          id: 1,
          company: "Freelance",
          position: "Design Engineer",
          location: "Remote",
          dateRange: "Aug 2025 – Present",
          logo: "🚀",
          bullets: [
            "Coded React landing pages for startups using Figma, React, Next and Tailwind."
          ],
        },
        {
          id: 2,
          company: "Pixen",
          position: "Part-time UI/UX Designer",
          location: "Remote",
          dateRange: "Aug 2025 – Present",
          logo: "",
          logoImage: "https://i.ibb.co/jkvFwRCF/Frame-11.png",
          bullets: [
            "Designed SaaS apps, landing pages and dashboards in Figma."
          ],
        },
        {
          id: 3,
          company: "MLSA CFD",
          position: "Design & Social Head",
          location: "Microsoft Learn Student Ambassador, FAST NUCES CFD",
          dateRange: "Aug 2024 – Present",
          logo: "",
          logoImage: "https://i.ibb.co/3yhthnMj/Frame-1-6.png",
          bullets: [
            "Solo-built Pakistan's first 100% digital student platform (React, Supabase, Tailwind).",
            "Design events posters and manage social media increasing engagement by 40%."
          ],
        },
        {
          id: 4,
          company: "Web3 Pak",
          position: "Ambassador",
          location: "Pakistan",
          dateRange: "May 2024 – Aug 2025",
          logo: "",
          logoImage: "https://media.licdn.com/dms/image/v2/C4E0BAQHpKChVcaUBqA/company-logo_200_200/company-logo_200_200/0/1670567732446?e=1772064000&v=beta&t=KoKZjXvKZh6Z8YS7Bqbf2EA8_a6U-B9V4ZLo_jDuA2Q",
          bullets: [
            "Selected for the Web3Pak Cohort 2 Ambassador Program."
          ],
        },
        {
          id: 5,
          company: "Circle AI",
          position: "UI/UX Intern",
          location: "Remote",
          dateRange: "Jun 2024 – Aug 2024",
          logo: "",
          logoImage: "https://i.ibb.co/j980RcMS/image.png",
          bullets: [
            "Designed AI chatbot UI (Material Design); cut onboarding 35%."
          ],
        },
        {
          id: 6,
          company: "SES FAST CFD",
          position: "Graphic Designer & Executive Body Member",
          location: "Software Engineering Society, FAST NUCES CFD",
          dateRange: "Aug 2023 – Jul 2024",
          logo: "",
          logoImage: "https://media.licdn.com/dms/image/v2/D4D0BAQFhP0Z53xVqFw/company-logo_200_200/company-logo_200_200/0/1699865941344?e=1772064000&v=beta&t=YUg1caAjV09mFS5R1VXA3wfbsKUk81ML-a0p18nca3w",
          bullets: [
            "Sole candidate selected directly to serve in the executive body as a freshman.",
            "Collaborated with final year students on design and society initiatives."
          ],
        },
      ].map((experience) => (
        <div
          class="flex flex-row gap-6 items-start text-left group hover:opacity-75 transition-opacity duration-300"
          data-aos="focus-up"
        >
          <!-- Company Logo -->
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 flex items-center justify-center text-xl overflow-hidden mt-1">
            {experience.logoImage ? (
              <img src={experience.logoImage} alt={`${experience.company} logo`} class="w-full h-full object-cover" />
            ) : (
              experience.logo
            )}
          </div>
          
          <!-- Experience Content -->
          <div class="flex-1 flex flex-col gap-1">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-baseline gap-1 sm:gap-4">
              <h3 class="text-base sm:text-lg font-product-sans font-bold text-gray-900 dark:text-gray-100">{experience.company}</h3>
              <span class="text-[10px] sm:text-xs text-gray-400 dark:text-gray-500 font-product-sans whitespace-nowrap">
                {experience.dateRange}
              </span>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:items-center gap-0.5 sm:gap-2">
              <p class="text-xs sm:text-sm font-medium text-gray-700 dark:text-gray-300 font-product-sans">
                {experience.position}
              </p>
              <span class="hidden sm:inline text-gray-300 dark:text-neutral-700">·</span>
              <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 font-product-sans">
                {experience.location}
              </p>
            </div>


          </div>
        </div>
      ))}
    </div>
  </div>
</section>
