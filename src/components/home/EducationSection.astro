---
---

<link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />

<section
  class="relative w-full flex justify-center overflow-hidden z-10 bg-white dark:bg-black"
  aria-labelledby="education-heading"
  data-aos="focus-up"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    
    <!-- Heading with Education Count -->
    <div class="flex items-end justify-between gap-4" data-aos="focus-up">
      <div>
        <h2 class="text-[50px] [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100" id="education-heading">
          education
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mt-2">3 institutions</p>
      </div>
    </div>

    <!-- Description -->
    <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl" data-aos="focus-up" data-aos-delay="100">
      My educational background in <strong>computer science</strong> and <strong>business administration</strong>.
    </p>

    <!-- Education Items -->
    <div class="flex flex-col gap-8 mt-4" data-aos="focus-up" data-aos-delay="200">
      {[
        {
          id: 1,
          institution: "Buildspace",
          degree: "s3, s4, sf1, s5",
          dateRange: "2023 - 2024",
          logo: "⬇️",
        },
        {
          id: 2,
          institution: "University of Waterloo",
          degree: "Bachelor's Degree of Computer Science (BCS)",
          dateRange: "2016 - 2021",
          logo: "🎓",
        },
        {
          id: 3,
          institution: "Wilfrid Laurier University",
          degree: "Bachelor's Degree of Business Administration (BBA)",
          dateRange: "2016 - 2021",
          logo: "🎓",
        },
      ].map((education) => (
        <div
          class="flex gap-4 sm:gap-6 items-start group hover:opacity-75 transition-opacity duration-300"
          data-aos="focus-up"
        >
          <!-- School Logo -->
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 flex items-center justify-center text-xl">
            {education.logo}
          </div>
          
          <!-- Education Content -->
          <div class="flex-1 flex flex-col gap-1">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-lg font-product-sans text-gray-900 dark:text-gray-100">{education.institution}</h3>
              <span class="text-xs text-gray-400 dark:text-gray-500 font-product-sans whitespace-nowrap">
                {education.dateRange}
              </span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans">
              {education.degree}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
