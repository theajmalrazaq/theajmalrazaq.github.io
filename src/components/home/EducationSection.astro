---
---


<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="education-heading"
  data-aos="focus-up"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-8 z-10">
    
    <!-- Heading with Education Count -->
    <div class="flex flex-col items-center justify-center gap-2 text-center" data-aos="focus-up">
      <div>
        <h2 class="text-[50px] [font-family:'GeistPixelGrid'] text-gray-900 dark:text-gray-100" id="education-heading">
          education
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mt-2">2 institutions</p>
      </div>
    </div>

    <!-- Description -->
    <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl mx-auto text-center" data-aos="focus-up" data-aos-delay="100">
      My educational background in <strong>computer science</strong> and <strong>leadership</strong>.
    </p>

    <!-- Education Items -->
    <div class="flex flex-col gap-10 mt-4" data-aos="focus-up" data-aos-delay="200">
      {[
        {
          id: 1,
          institution: "National University of Computer and Emerging Sciences",
          degree: "Bachelor, Computer Science",
          dateRange: "2023 – 2027",
          logo: "",
          logoImage: "https://media.licdn.com/dms/image/v2/D4D0BAQEhCkUcTCTUsA/company-logo_200_200/B4DZbEm8GEHsAI-/0/1747055264905/fastnu_logo?e=1772064000&v=beta&t=Pw0f3wbXeDJHedKn52Cd7fyC_8oG4YMNO09VrAk4opk",
        },
        {
          id: 2,
          institution: "Aspire Institute",
          degree: "Educational Leadership and Administration, General",
          dateRange: "Apr 2024 – Aug 2024",
          logo: "",
          logoImage: "https://media.licdn.com/dms/image/v2/D4E0BAQFMttlyatjAKQ/company-logo_200_200/company-logo_200_200/0/1683218290650/aspire_leaders_program_logo?e=1772064000&v=beta&t=D4QpAQAkXoWNHL00mikRtcu0pCj-fAYIxl1UvR-TF4M",
        },
      ].map((education) => (
        <div
          class="flex flex-row gap-6 items-start text-left group hover:opacity-75 transition-opacity duration-300"
          data-aos="focus-up"
        >
          <!-- School Logo -->
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 flex items-center justify-center text-xl overflow-hidden mt-1">
            {education.logoImage ? (
              <img src={education.logoImage} alt={`${education.institution} logo`} class="w-full h-full object-cover" />
            ) : (
              education.logo
            )}
          </div>
          
          <!-- Education Content -->
          <div class="flex-1 flex flex-col gap-1">
            <div class="flex flex-row justify-between items-baseline gap-4">
              <h3 class="text-lg font-product-sans font-bold text-gray-900 dark:text-gray-100">{education.institution}</h3>
              <span class="text-xs text-gray-400 dark:text-gray-500 font-product-sans whitespace-nowrap">
                {education.dateRange}
              </span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans">
              {education.degree}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
