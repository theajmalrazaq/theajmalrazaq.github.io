---
import ProjectList from "./ProjectList.jsx";

// Fetch GitHub repos at build time
const username = "theajmalrazaq";
const response = await fetch(`https://api.github.com/users/${username}/repos?sort=updated&per_page=100&type=owner`);
const allRepos = await response.json();

// Filter out forks and the portfolio repo, sort by stars
const projects = allRepos
  .filter((repo: any) => !repo.fork && repo.name !== `${username}.github.io`)
  .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count);

// Serialize only the fields we need (avoid passing non-serializable data)
const serializedProjects = projects.map((repo: any) => ({
  id: repo.id,
  name: repo.name,
  html_url: repo.html_url,
  description: repo.description,
  language: repo.language,
  stargazers_count: repo.stargazers_count,
  forks_count: repo.forks_count,
  topics: repo.topics || [],
}));
---

<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="projects-heading"
>
  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-6 z-10">
    <ProjectList projects={serializedProjects} client:load />
  </div>
</section>
