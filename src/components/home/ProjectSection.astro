---
import ProjectList from "./ProjectList.jsx";

// Fetch GitHub repos at build time
const username = "theajmalrazaq";
const response = await fetch(
  `https://api.github.com/users/${username}/repos?sort=updated&per_page=100&type=owner`,
);
const allRepos = await response.json();

// Filter out forks and the portfolio repo, sort by stars
const projects = allRepos
  .filter((repo: any) => !repo.fork && repo.name !== `${username}.github.io`)
  .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count);

// Serialize only the fields we need (avoid passing non-serializable data)
const serializedProjects = projects.map((repo: any) => ({
  id: repo.id,
  name: repo.name,
  html_url: repo.html_url,
  description: repo.description,
  language: repo.language,
  stargazers_count: repo.stargazers_count,
  forks_count: repo.forks_count,
  topics: repo.topics || [],
}));
---

<section
  class="relative w-full flex justify-center overflow-hidden z-10"
  aria-labelledby="projects-heading"
  data-aos="focus-up"
>
  <div
    class="relative w-full max-w-4xl mx-auto px-4 sm:px-15 py-6 sm:py-8 flex flex-col gap-4 z-10"
  >
    <div
      class="flex flex-col items-center justify-center text-center gap-4"
      data-aos="focus-up"
      data-aos-delay="100"
    >
      <h2
        class="text-[40px] sm:text-[50px] [font-family:'GeistPixelGrid'] text-gray-900 dark:text-gray-100"
        id="projects-heading"
      >
        projects
      </h2>
      <p
        class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl mx-auto text-center"
      >
        My open source projects and repositories on <strong>GitHub</strong>.
      </p>
    </div>

    <div data-aos="focus-up" data-aos-delay="200">
      <ProjectList projects={serializedProjects} client:load />
    </div>
  </div>
</section>
