---
import { Image } from "astro:assets";
import arrow_right from "../../images/arrow_right.svg";
import star from "../../images/star.svg";
import Heading from "../Heading.astro";
import StarBorder from "../../components/StarBorder.jsx";
import devimg from "../../images/ajmalo.png";
import logowhite from "../../images/logowhite.svg";
---

<link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />

<header class="relative w-full flex justify-center overflow-hidden z-10 bg-white dark:bg-black" data-aos="focus-up">
  
  <!-- Screen reader only heading for accessibility -->
  <h1 class="sr-only">Ajmal Razaq | Design Engineer Portfolio</h1>

  <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col items-start justify-start gap-8 sm:gap-10 z-10">
    
    <!-- Profile Image -->
    <div data-aos="focus-up">
      <div
        class="group cursor-none relative w-[140px] h-[140px] rounded-full overflow-hidden border-4 border-gray-200 dark:border-neutral-800 hover:border-accent/50 transition-all duration-300 bg-gradient-to-br from-accent/5 to-transparent shadow-lg"
        role="img"
        aria-label="Ajmal Razaq profile picture"
      >
        <Image
          src={devimg}
          alt="Ajmal Razaq - Design Engineer portrait"
          loading="eager"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
      </div>
    </div>

    <!-- Left Content - Text -->
    <div class="flex flex-col gap-6 flex-1" data-aos="focus-up" data-aos-delay="100">
      <!-- Main Content -->
      <div class="flex flex-col gap-4">
        <!-- Name -->
        <div>
          <h2 class="text-[50px] leading-tight [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100">
            ajmal razaq
          </h2>
          <p class="text-lg font-bold sm:text-xl text-gray-500 dark:text-gray-400 font-product-sans mt-2">
            Design Engineer
          </p>
        </div>

        <!-- Description -->
        <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-lg">
          A Design Engineer Who Loves Building Products That Solve Real Problems Using a Blend of Design and Code.
        </p>
      </div>

      <!-- Social Links -->
      <div
        class="flex flex-wrap items-center gap-3"
        role="navigation"
        aria-label="Social media links"
        data-aos="focus-up"
        data-aos-delay="200"
      >
        <a
          href="https://github.com/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="GitHub profile"
        >
          <i class="hgi-stroke hgi-github-01 text-lg"></i>
          <span>GitHub</span>
        </a>
        <a
          href="https://linkedin.com/in/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="LinkedIn profile"
        >
          <i class="hgi hgi-stroke hgi-linkedin-01 text-lg"></i>
          <span>LinkedIn</span>
        </a>
       
        <a
          href="https://behance.net/theajmalrazaq"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-product-sans text-gray-700 dark:text-gray-300 hover:text-accent hover:bg-accent/10 rounded-full transition-all duration-300 cursor-none border border-gray-200 dark:border-neutral-800 hover:border-accent/30"
          aria-label="Behance portfolio"
        >
         <i class="hgi hgi-stroke hgi-behance-02 text-lg"></i>
          <span>Behance</span>
        </a>
      </div>
    </div>
  </div>
</header>