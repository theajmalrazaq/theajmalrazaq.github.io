---
import "../../styles/global.css";
import { Image } from "astro:assets";
import dev from "../../images/dev.webp";
import { getCollection, render } from "astro:content";
import NavbarSection from "../../components/NavbarSection.astro";
import Loading from "../../components/Loading.astro";
import CursorTracker from "../../components/CursorTracker.astro";
import FooterSection from "../../components/FooterSection.astro";
import MetaSection from "../../components/MetaSection.astro";

// Generate static paths from content collection
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { slug } = Astro.params;
const { Content } = await render(post);

// Get related posts (all posts except current, pick random 2)
const allPosts = await getCollection("blog");
const otherPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort(() => 0.5 - Math.random())
  .slice(0, 2);
---

<!doctype html>
<html lang="en" class="lenis lenis--smooth select-none">
  <MetaSection
    title={`${post.data.title} | Ajmal Razaq`}
    description={post.data.excerpt || "An article by Ajmal Razaq"}
    keywords={[
      "blog",
      "article",
      "frontend development",
      "UI/UX design",
      "ajmal razaq",
    ]}
    socialImage={post.data.img || "/images/social-share.png"}
    url={`https://theajmalrazaq.github.io/blog/${slug}`}
    type="article"
  />

  <script is:inline>
    (function () {
      const theme = localStorage.getItem("theme") || "system";
      if (
        theme === "dark" ||
        (theme === "system" &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    })();
  </script>
  <body
    class="bg-white dark:bg-black min-h-screen flex flex-col transition-colors duration-300"
  >
    <CursorTracker />
    <Loading />
    <NavbarSection page="blog" />

    <main class="flex-grow">
      <article role="main">
        <!-- Header -->
        <section class="relative w-full flex justify-center overflow-hidden z-10">
          <div
            class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 pt-6 sm:pt-8 pb-2 flex flex-col gap-4 z-10"
          >
            <!-- Back Link -->
            <a
              href="/blog"
              class="inline-flex items-center gap-1.5 text-sm font-product-sans text-gray-500 dark:text-gray-400 hover:text-accent transition-colors duration-300 w-fit"
              aria-label="Return to blog listing page"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.75 19.5 8.25 12l7.5-7.5"></path>
              </svg>
              back to blog
            </a>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {
                post.data.tags.map((tag) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 bg-gray-50 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full text-xs font-product-sans text-gray-600 dark:text-gray-400">
                    {tag}
                  </span>
                ))
              }
            </div>

            <!-- Title -->
            <h1
              class="text-[50px] leading-tight [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100 capitalize"
            >
              {post.data.title}
            </h1>

            <!-- Excerpt -->
            {
              post.data.excerpt && (
                <p class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl">
                  {post.data.excerpt}
                </p>
              )
            }

            <!-- Author & Meta -->
            <div class="flex gap-4 items-center justify-between flex-wrap mt-2">
              <div class="flex gap-3 items-center">
                <div
                  class="w-10 h-10 rounded-full overflow-hidden border-2 border-gray-200 dark:border-neutral-800"
                >
                  <Image
                    src={dev}
                    alt="Ajmal Razaq - Author profile photo"
                    loading="eager"
                    class="w-full h-full object-cover"
                  />
                </div>
                <div class="flex-1">
                  <p
                    class="text-sm font-product-sans font-bold text-gray-900 dark:text-gray-100"
                  >
                    Ajmal Razaq
                  </p>
                  <time
                    class="text-xs font-product-sans text-gray-500 dark:text-gray-400"
                    datetime={post.data.date.toISOString()}
                  >
                    {
                      post.data.date.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })
                    }
                  </time>
                </div>
              </div>

              <span
                class="text-xs text-gray-400 dark:text-gray-500 font-product-sans"
              >
                {post.data.readTime} min read
              </span>
            </div>
          </div>
        </section>

        <!-- Cover Image -->
        {
          post.data.img && (
            <section class="relative w-full flex justify-center overflow-hidden z-10">
              <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-4 z-10">
                <img
                  src={post.data.img}
                  alt={`Cover image for article: ${post.data.title}`}
                  loading="eager"
                  decoding="async"
                  class="w-full aspect-video rounded-2xl object-cover border border-gray-200 dark:border-neutral-800"
                />
              </div>
            </section>
          )
        }

        <!-- Article Content -->
        <section class="relative w-full flex justify-center overflow-hidden z-10">
          <div
            class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 z-10"
          >
            <article
              class="mdx prose max-w-none transition-colors
                prose-p:font-product-sans prose-p:text-gray-600 dark:prose-p:text-neutral-400
                prose-img:rounded-2xl
                prose-a:text-accent prose-a:underline prose-a:decoration-accent prose-a:decoration-2 prose-a:hover:decoration-4
                prose-ul:text-gray-600 dark:prose-ul:text-neutral-400
                prose-ol:text-gray-600 dark:prose-ol:text-neutral-400
                prose-li:text-gray-600 dark:prose-li:text-neutral-400
                prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-gray-100
                prose-pre:bg-gray-50 dark:prose-pre:bg-neutral-900 prose-pre:border prose-pre:border-gray-200 dark:prose-pre:border-neutral-800 prose-pre:rounded-lg prose-pre:p-4 prose-pre:font-mono prose-pre:text-sm
                prose-code:bg-gray-100 dark:prose-code:bg-neutral-800 prose-code:text-accent prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:font-mono prose-code:text-sm
                prose-blockquote:border-l-4 prose-blockquote:border-accent prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-gray-500 dark:prose-blockquote:text-neutral-400
                prose-strong:text-gray-900 dark:prose-strong:text-gray-100
                prose-em:text-gray-600 dark:prose-em:text-neutral-300 prose-em:italic
                prose-hr:border-gray-200 dark:prose-hr:border-neutral-800
                prose-table:border-collapse
                prose-thead:border-b-2 prose-thead:border-gray-200 dark:prose-thead:border-neutral-800
                prose-th:text-gray-900 dark:prose-th:text-gray-100 prose-th:font-bold prose-th:px-4 prose-th:py-2
                prose-td:text-gray-600 dark:prose-td:text-neutral-400 prose-td:px-4 prose-td:py-2 prose-td:border-b prose-td:border-gray-200 dark:prose-td:border-neutral-800"
            >
              <Content />
            </article>
          </div>
        </section>

        <!-- You Might Like Section -->
        {
          otherPosts.length > 0 && (
            <section class="relative w-full flex justify-center overflow-hidden z-10">
              <div class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-6 z-10">
                <div class="border-t border-gray-200 dark:border-neutral-800 pt-8">
                  <h2 class="text-[50px] [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100 mb-6">
                    related
                  </h2>

                  <div class="flex flex-col gap-6">
                    {otherPosts.map((relatedPost, index) => (
                      <a
                        href={`/blog/${relatedPost.id}`}
                        class="flex gap-4 sm:gap-6 items-start group hover:opacity-75 transition-opacity duration-300"
                        aria-label={`Read related article: ${relatedPost.data.title}`}
                      >
                        <div class="flex-shrink-0 text-gray-500 dark:text-gray-400 [font-family:'GeistPixelSquare'] text-lg font-bold w-12">
                          {String(index + 1).padStart(2, "0")}.
                        </div>
                        <div class="flex-1 flex flex-col gap-1">
                          <h3 class="text-lg font-product-sans font-bold text-gray-900 dark:text-gray-100 capitalize">
                            {relatedPost.data.title}
                          </h3>
                          <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans leading-relaxed line-clamp-2">
                            {relatedPost.data.excerpt}
                          </p>
                          <div class="flex flex-wrap items-center gap-3 mt-1">
                            <time
                              datetime={relatedPost.data.date.toISOString()}
                              class="text-xs text-gray-400 dark:text-gray-500 font-product-sans"
                            >
                              {relatedPost.data.date.toLocaleDateString(
                                "en-US",
                                {
                                  month: "long",
                                  day: "2-digit",
                                  year: "numeric",
                                }
                              )}
                            </time>
                            <span class="text-xs text-gray-400 dark:text-gray-500 font-product-sans">
                              · {relatedPost.data.readTime} min read
                            </span>
                          </div>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </section>
          )
        }
      </article>
    </main>

    <FooterSection />
    <script type="module" src="/script.js"></script>
  </body>
</html>
