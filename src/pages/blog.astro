---
import "../styles/global.css";
import { getCollection } from "astro:content";
import NavbarSection from "../components/NavbarSection.astro";
import Loading from "../components/Loading.astro";
import FooterSection from "../components/FooterSection.astro";
import CursorTracker from "../components/CursorTracker.astro";
import MetaSection from "../components/MetaSection.astro";

// Get all blog posts from content collection
const posts = await getCollection("blog");
const blog = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const allTags = [...new Set(blog.flatMap((post) => post.data.tags))];
---

<!doctype html>
<html lang="en" class="lenis lenis--smooth select-none">
  <MetaSection
    title="Blog | Ajmal Razaq"
    description="Articles and thoughts by Ajmal Razaq on frontend development, UI/UX design, and more."
    keywords={[
      "blog",
      "articles",
      "frontend development",
      "UI/UX design",
      "ajmal razaq",
    ]}
    url="https://theajmalrazaq.github.io/blog"
    type="website"
  />

  <script is:inline>
    (function () {
      const theme = localStorage.getItem("theme") || "system";
      if (
        theme === "dark" ||
        (theme === "system" &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    })();
  </script>
  <body
    class="bg-white dark:bg-black min-h-screen flex flex-col transition-colors duration-300"
  >
    <CursorTracker />
    <Loading />
    <NavbarSection page="blog" />

    <main>
      <!-- Header Section -->
      <section
        class="relative w-full flex justify-center overflow-hidden z-10"
        aria-labelledby="blog-heading"
      >
        <div
          class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 pt-6 sm:pt-8 pb-2 flex flex-col gap-6 z-10"
        >
          <!-- Heading -->
          <div>
            <h1
              id="blog-heading"
              class="text-[50px] [font-family:'GeistPixelSquare'] text-gray-900 dark:text-gray-100"
            >
              blog
            </h1>
            <p
              class="text-sm text-gray-500 dark:text-gray-400 font-product-sans mt-2"
            >
              {blog.length} posts
            </p>
          </div>

          <!-- Description -->
          <p
            class="text-base text-gray-600 dark:text-gray-400 font-product-sans leading-relaxed max-w-3xl"
          >
            Thoughts, tutorials, and insights on <strong
              >frontend development</strong
            > and <strong>design</strong>.
          </p>

          <!-- Search Bar -->
          <div class="flex flex-col gap-4">
            <div class="relative w-full max-w-md">
              <label for="search-input" class="sr-only"
                >Search articles by title or content</label
              >
              <input
                type="text"
                id="search-input"
                placeholder="Search articles..."
                class="w-full px-4 py-2.5 border border-gray-200 dark:border-neutral-800 rounded-full text-gray-900 dark:text-gray-100 focus:outline-none bg-gray-50 dark:bg-neutral-900 focus:border-accent/50 transition-all text-sm font-product-sans pr-10"
              />
              <svg
                class="absolute right-3.5 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 dark:text-gray-500"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                ></path>
              </svg>
            </div>

            <!-- Tag Pills -->
            <div
              class="flex flex-wrap gap-2"
              role="group"
              aria-label="Filter articles by category"
            >
              <button
                id="filter-all"
                class="text-xs px-3 py-1.5 rounded-full bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 font-product-sans transition-all duration-300 filter-active"
                aria-pressed="true"
                aria-label="Show all articles"
              >
                All
              </button>
              {
                allTags.map((tag) => (
                  <button
                    class="text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 text-gray-600 dark:text-gray-400 hover:bg-accent/10 hover:border-accent/30 hover:text-accent font-product-sans transition-all duration-300 filter-tag"
                    data-tag={tag}
                    aria-pressed="false"
                    aria-label={`Filter articles by ${tag}`}
                  >
                    {tag}
                  </button>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <!-- Blog Posts Section -->
      <section class="relative w-full flex justify-center overflow-hidden z-10">
        <div
          class="relative w-full max-w-4xl mx-auto px-6 sm:px-15 py-6 sm:py-8 flex flex-col gap-6 z-10"
        >
          <!-- No Results Message -->
          <div
            id="no-results-message"
            class="hidden text-center py-10"
            role="status"
            aria-live="polite"
          >
            <p
              class="text-lg text-gray-500 dark:text-gray-400 font-product-sans"
            >
              No results found. Try different keywords or remove filters.
            </p>
          </div>

          <!-- Blog Posts List -->
          <div id="blog-posts-container" class="flex flex-col gap-6">
            {
              blog.map((post, index) => (
                <a
                  href={`/blog/${post.id}`}
                  class="blog-card flex gap-4 sm:gap-6 items-start group hover:opacity-75 transition-opacity duration-300"
                  data-tags={post.data.tags.join(",")}
                  data-blog-id={post.id}
                  aria-label={`Read article: ${post.data.title}`}
                >
                  {/* Post Number */}
                  <div class="flex-shrink-0 text-gray-500 dark:text-gray-400 [font-family:'GeistPixelSquare'] text-lg font-bold w-12">
                    {String(index + 1).padStart(2, "0")}.
                  </div>

                  {/* Post Content */}
                  <div class="flex-1 flex flex-col gap-1">
                    <h2 class="text-lg font-product-sans font-bold text-gray-900 dark:text-gray-100 capitalize">
                      {post.data.title}
                    </h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400 font-product-sans leading-relaxed line-clamp-2">
                      {post.data.excerpt}
                    </p>
                    <div class="flex flex-wrap items-center gap-3 mt-1">
                      <time
                        datetime={post.data.date.toISOString()}
                        class="text-xs text-gray-400 dark:text-gray-500 font-product-sans"
                      >
                        {post.data.date.toLocaleDateString("en-US", {
                          month: "long",
                          day: "2-digit",
                          year: "numeric",
                        })}
                      </time>
                      <span class="text-xs text-gray-400 dark:text-gray-500 font-product-sans">
                        · {post.data.readTime} min read
                      </span>
                      {post.data.tags.map((tag) => (
                        <span class="inline-flex items-center px-2.5 py-0.5 bg-gray-50 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 rounded-full text-xs font-product-sans text-gray-600 dark:text-gray-400">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <FooterSection />
    <script type="module" src="/script.js"></script>

    <script>
      // Search functionality
      const searchInput = document.getElementById("search-input");
      const blogCards = document.querySelectorAll(".blog-card");
      const noResults = document.getElementById("no-results-message");
      const filterAll = document.getElementById("filter-all");
      const filterTags = document.querySelectorAll(".filter-tag");

      let activeTag = "all";

      function filterPosts() {
        const query = (searchInput as HTMLInputElement)?.value.toLowerCase() || "";
        let visibleCount = 0;

        blogCards.forEach((card) => {
          const title = card.querySelector("h2")?.textContent?.toLowerCase() || "";
          const excerpt = card.querySelector("p")?.textContent?.toLowerCase() || "";
          const tags = card.getAttribute("data-tags") || "";

          const matchesSearch = title.includes(query) || excerpt.includes(query);
          const matchesTag = activeTag === "all" || tags.split(",").includes(activeTag);

          if (matchesSearch && matchesTag) {
            (card as HTMLElement).style.display = "";
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = "none";
          }
        });

        if (noResults) {
          noResults.style.display = visibleCount === 0 ? "block" : "none";
        }
      }

      searchInput?.addEventListener("input", filterPosts);

      filterAll?.addEventListener("click", () => {
        activeTag = "all";
        filterAll.className =
          "text-xs px-3 py-1.5 rounded-full bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 font-product-sans transition-all duration-300 filter-active";
        filterTags.forEach((btn) => {
          btn.className =
            "text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 text-gray-600 dark:text-gray-400 hover:bg-accent/10 hover:border-accent/30 hover:text-accent font-product-sans transition-all duration-300 filter-tag";
        });
        filterPosts();
      });

      filterTags.forEach((btn) => {
        btn.addEventListener("click", () => {
          activeTag = btn.getAttribute("data-tag") || "all";
          if (filterAll) {
            filterAll.className =
              "text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 text-gray-600 dark:text-gray-400 hover:bg-accent/10 hover:border-accent/30 hover:text-accent font-product-sans transition-all duration-300 filter-active";
          }
          filterTags.forEach((b) => {
            b.className =
              "text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-neutral-800 text-gray-600 dark:text-gray-400 hover:bg-accent/10 hover:border-accent/30 hover:text-accent font-product-sans transition-all duration-300 filter-tag";
          });
          btn.className =
            "text-xs px-3 py-1.5 rounded-full bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 font-product-sans transition-all duration-300 filter-tag";
          filterPosts();
        });
      });
    </script>
  </body>
</html>
